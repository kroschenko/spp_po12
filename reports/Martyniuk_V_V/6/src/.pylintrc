[MASTER]
# Рекурсивный обход папок
recursive=yes

# Игнорируемые файлы/папки
ignore=__pycache__,venv,env,.venv,.git,.pytest_cache,migrations

[MESSAGES CONTROL]
# Отключаем проблемные проверки для тестов
disable=
    C0114,  # missing-module-docstring
    C0115,  # missing-class-docstring
    C0116,  # missing-function-docstring
    C0304,  # missing-final-newline
    C0305,  # trailing-newlines
    C0103,  # invalid-name
    W0621,  # redefined-outer-name (pytest fixtures)
    W0613,  # unused-argument (pytest fixtures)
    W0611,  # unused-import
    R0902,  # too-many-instance-attributes
    R0903,  # too-few-public-methods
    R0904,  # too-many-public-methods
    R0913,  # too-many-arguments
    R0917,  # too-many-positional-arguments
    R0801,  # duplicate-code
    E1101,  # no-member (pygame dynamic)
    C0411,  # wrong-import-order
    W0401,  # wildcard-import
    W0614,  # unused-wildcard-import
    R1705,  # no-else-return
    R1730,  # consider-using-min-builtin
    R0912,  # too-many-branches
    E1120,  # no-value-for-parameter

[FORMAT]
# Максимальная длина строки
max-line-length=120

[BASIC]
# Допустимые имена переменных
good-names=i,j,k,ex,Run,_,x,y,item,fs,id,ip,db,cart,repo

[REPORTS]
# Вывод оценки
score=yes

# Формат вывода
output-format=colorized

[TYPECHECK]
# Игнорировать ошибки типов для pygame
ignored-modules=pygame
ignored-classes=pygame

# Не проверять типы для этих методов
generated-members=pygame.*